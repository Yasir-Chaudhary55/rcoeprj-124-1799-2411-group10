<% layout("/layouts/boilerplate.ejs") %>

<div class="container">
  <div class="section-header">
    <h2>Edit Member</h2>
    <a href="/members" class="btn secondary">← Back to Members</a>
  </div>

  <div class="form-container">
    <div class="modal-content">
      <form action="/members/<%= member._id %>?_method=PUT" method="POST">

        <div class="form-group">
          <label>Name</label>
          <input type="text" name="name" value="<%= member.name %>" required />
        </div>

        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" value="<%= member.email %>" required />
        </div>

        <div class="form-group">
          <label>Phone</label>
          <input type="text" name="phone" value="<%= member.phone %>" required />
        </div>

        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="Active"   <%= member.status === 'Active'   ? 'selected' : '' %>>Active</option>
            <option value="Inactive" <%= member.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>

        <div class="form-actions">
          <a href="/members" class="btn secondary">Cancel</a>
          <button type="submit" class="btn primary">Update Member</button>
        </div>

      </form>
    </div>
  </div>
</div>