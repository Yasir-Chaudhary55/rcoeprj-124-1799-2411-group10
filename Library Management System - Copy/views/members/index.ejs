<% layout("/layouts/boilerplate.ejs") %>

<div class="container">
  <section id="members" class="tab-content active">

    <div class="section-header">
      <h2>Member Management</h2>
      <a href="/members/new" class="btn primary">+ Add New Member</a>
    </div>

    <form class="search-filter" method="GET" action="/members">
      <input
        type="text"
        name="search"
        placeholder="Search members by name or email..."
        value="<%= typeof search !== 'undefined' ? search : '' %>"
      />
      <select name="status" onchange="this.form.submit()">
        <option value="">All Status</option>
        <option value="Active"   <%= typeof status !== 'undefined' && status === 'Active'   ? 'selected' : '' %>>Active</option>
        <option value="Inactive" <%= typeof status !== 'undefined' && status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
      </select>
      <button type="submit" style="display:none"></button>
    </form>

    <div class="table-container">
      <table id="membersTable">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Books Borrowed</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% members.forEach((member) => { %>
            <tr>
              <td><%= member.name %></td>
              <td><%= member.email %></td>
              <td><%= member.phone %></td>
              <td>
                <span class="status <%= member.status === 'Active' ? 'active' : 'inactive' %>">
                  <%= member.status %>
                </span>
              </td>
              <td><%= member.booksBorrowed %></td>
              <td>
                <a href="/members/<%= member._id %>/edit" class="action-btn edit">Edit</a>
                <form action="/members/<%= member._id %>?_method=DELETE" method="POST" style="display: inline-block">
                  <button type="submit" class="action-btn delete"
                    onclick="return confirm('Are you sure you want to delete this member?');">
                    Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </section>
</div>