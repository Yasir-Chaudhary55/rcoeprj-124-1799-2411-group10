<% layout("/layouts/boilerplate.ejs") %>

<div class="container">
  <section id="books" class="tab-content active">

    <div class="section-header">
      <h2>Book Management</h2>
      <a href="/books/new" class="btn primary">+ Add New Book</a>
    </div>

    <form class="search-filter" method="GET" action="/books">
      <input
  type="text"
  name="search"
  placeholder="Search by book name or author..."
  value="<%= typeof search !== 'undefined' ? search : '' %>"
/>
<select name="category" onchange="this.form.submit()">
  <option value="">All Categories</option>
  <option value="Fiction"     <%= typeof category !== 'undefined' && category === 'Fiction'     ? 'selected' : '' %>>Fiction</option>
  <option value="Non-Fiction" <%= typeof category !== 'undefined' && category === 'Non-Fiction' ? 'selected' : '' %>>Non-Fiction</option>
  <option value="Science"     <%= typeof category !== 'undefined' && category === 'Science'     ? 'selected' : '' %>>Science</option>
  <option value="History"     <%= typeof category !== 'undefined' && category === 'History'     ? 'selected' : '' %>>History</option>
  <option value="Biography"   <%= typeof category !== 'undefined' && category === 'Biography'   ? 'selected' : '' %>>Biography</option>
  <option value="Technology"  <%= typeof category !== 'undefined' && category === 'Technology'  ? 'selected' : '' %>>Technology</option>
  <option value="Romance"     <%= typeof category !== 'undefined' && category === 'Romance'     ? 'selected' : '' %>>Romance</option>
  <option value="Mystery"     <%= typeof category !== 'undefined' && category === 'Mystery'     ? 'selected' : '' %>>Mystery</option>
</select>
      <button type="submit" style="display:none"></button>
    </form>

    <div class="table-container">
      <table id="booksTable">
        <thead>
          <tr>
            <th>Book Name</th>
            <th>Author</th>
            <th>Category</th>
            <th>Total Copies</th>
            <th>Available</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% books.forEach((book) => { %>
            <tr>
              <td><%= book.bookName %></td>
              <td><%= book.authorName %></td>
              <td><%= book.category %></td>
              <td><%= book.quantity %></td>
              <td><%= book.available %></td>
              <td>
                <span class="status <%= book.available > 0 ? 'available' : 'issued' %>">
                  <%= book.available > 0 ? 'Available' : 'Issued' %>
                </span>
              </td>
              <td>
                <a href="/books/<%= book._id %>/edit" class="action-btn edit">Edit</a>
                <form action="/books/<%= book._id %>?_method=DELETE" method="POST" style="display: inline-block">
                  <button type="submit" class="action-btn delete"
                    onclick="return confirm('Are you sure you want to delete this book?');">
                    Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </section>
</div>