<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header>
    <h1>
      📚 Library Management System
    </h1>
  </header>
  <div class="container">
  <div style="display:flex; justify-content:center; align-items:center; min-height:80vh;">
    <div class="modal-content" style="width:100%; max-width:420px;">

      <h3 style="text-align:center; margin-bottom:2rem;">📚 Library Management System</h3>
      <p style="text-align:center; color:#6c757d; margin-bottom:2rem;">Please select how you want to login</p>

      <div style="display:flex; gap:1rem; flex-direction:column;">

        <a href="/login/admin" class="btn primary" style="text-align:center; padding:1rem; font-size:1.1rem;">
          🔐 Login as Admin
        </a>

        <a href="/user/login" class="btn secondary" style="text-align:center; padding:1rem; font-size:1.1rem;">
          👤 Login as User
        </a>

      </div>

    </div>
  </div>
</div>
</body>
</html>