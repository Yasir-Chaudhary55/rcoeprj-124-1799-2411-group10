<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Library Management System</title>

    <link rel="stylesheet" href="/css/style.css" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
  </head>

  <body>
    <div class="container">
      <header>
        <h1>📚 Library Management System</h1>

        <nav>
          <a
            href="/books"
            class="nav-btn <%= currentPath === '/books' ? 'active' : '' %>"
          >
            Books
          </a>

          <a
            href="/members"
            class="nav-btn <%= currentPath === '/members' ? 'active' : '' %>"
          >
            Members
          </a>

          <a
            href="/transactions"
            class="nav-btn <%= currentPath === '/transactions' ? 'active' : '' %>"
          >
            Transactions
          </a>

          <a
            href="/dashboard"
            class="nav-btn <%= currentPath === '/dashboard' ? 'active' : '' %>"
          >
            Dashboard
          </a>
          <a
            href="/admin/requests"
            class="nav-btn <%= currentPath === '/admin/requests' ? 'active' : '' %>"
            >Requests</a
          >
        </nav>
        <a
          href="/logout"
          class="nav-btn"
          style="position: absolute; top: 1.5rem; right: 2rem"
          >🚪 Logout</a
        >
      </header>

      <main><%- body %></main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
