<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Security Question</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header><h1>📚 Library Management System</h1></header>
  <div class="container">
  <div style="display:flex;justify-content:center;align-items:center;min-height:80vh;">
    <div class="modal-content" style="width:100%;max-width:460px;">
      <div style="text-align:center;margin-bottom:1rem;">
        <a href="/user/profile" style="color:#667eea;text-decoration:none;font-size:0.9rem;">← Back to Profile</a>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <p style="color:#dc3545;text-align:center;margin-bottom:1rem;background:#f8d7da;padding:0.7rem;border-radius:6px;"><%= error %></p>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <p style="color:#155724;text-align:center;margin-bottom:1rem;background:#d4edda;padding:0.7rem;border-radius:6px;"><%= success %></p>
      <% } %>
      <h3 style="text-align:center;margin-bottom:0.4rem;">🛡️ Security Question</h3>
      <p style="text-align:center;color:#6c757d;font-size:0.88rem;margin-bottom:1.5rem;">
        <%= currentQuestion ? 'Update your security question below.' : 'Set a security question so you can reset your password if you forget it.' %>
      </p>
      <form action="/user/security-question" method="POST">
        <div class="form-group">
          <label>Select a Question</label>
          <select name="question" required>
            <option value="">-- Choose a question --</option>
            <% questions.forEach(q => { %>
              <option value="<%= q %>" <%= (currentQuestion === q) ? 'selected' : '' %>><%= q %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Your Answer</label>
          <input type="text" name="answer" required placeholder="Enter your answer (case-insensitive)" autocomplete="off" />
          <small style="color:#6c757d;font-size:0.8rem;">Your answer is stored securely and is not case-sensitive.</small>
        </div>
        <div class="form-actions" style="justify-content:center;">
          <button type="submit" class="btn primary" style="width:100%;">Save Security Question</button>
        </div>
      </form>
    </div>
  </div>
  </div>
</body>
</html>
