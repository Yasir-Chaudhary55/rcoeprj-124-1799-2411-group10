<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <h1>
      📚 Library Management System
    </h1>
  </header>
  <div class="container">
  <div class="section-header">
    <h2>👤 My Profile</h2>
    <a href="/user/dashboard" class="btn secondary">← Back to Dashboard</a>
  </div>

  <div class="form-container">
    <div class="modal-content" style="width:100%; max-width:500px;">

      <% if (typeof error !== 'undefined' && error) { %>
        <p style="color:#dc3545; margin-bottom:1rem; text-align:center;"><%= error %></p>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <p style="color:#28a745; margin-bottom:1rem; text-align:center;"><%= success %></p>
      <% } %>

      <!-- Profile Info -->
      <div style="text-align:center; margin-bottom:2rem;">
        <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg, #667eea, #764ba2);
          display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; font-size:2rem; color:white;">
          <%= userProfile.name.charAt(0).toUpperCase() %>
        </div>
        <h3><%= userProfile.name %></h3>
        <p style="color:#6c757d;"><%= userProfile.email %></p>
      </div>

      <form action="/user/profile?_method=PUT" method="POST">

        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" value="<%= userProfile.name %>" required />
        </div>

        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" value="<%= userProfile.email %>" required />
        </div>

        <div class="form-group">
          <label>Phone Number</label>
          <input type="text" name="phone" value="<%= userProfile.phone %>" required />
        </div>

        <div class="form-group">
          <label>New Password <span style="color:#aaa; font-weight:400;">(leave blank to keep current)</span></label>
          <input type="password" name="password" placeholder="Enter new password" />
        </div>

        <div class="form-actions" style="justify-content:center;">
          <button type="submit" class="btn primary" style="width:100%;">Update Profile</button>
        </div>

      </form>

      <!-- Security Question Card -->
      <div style="margin-top:1.5rem; background:#f0f4ff; border-radius:12px; padding:1.2rem 1.4rem; border-left:4px solid #667eea;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div>
            <p style="font-weight:700; color:#333; margin-bottom:0.2rem;">🛡️ Security Question</p>
            <p style="font-size:0.82rem; color:#6c757d; margin:0;">Used to recover your account if you forget your password.</p>
          </div>
          <a href="/user/security-question" class="btn primary" style="white-space:nowrap; font-size:0.82rem; padding:0.5rem 1rem;">Manage →</a>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>